{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "http://98.80.217.4/api/:path*"
    },
    {
      "source": "/socket.io/:path*",
      "destination": "http://98.80.217.4/socket.io/:path*"
    },
    {
      "source": "/((?!api/|socket.io/).*)",
      "destination": "/"
    }
  ]
}
